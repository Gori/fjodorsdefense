  "worlds": [
    {
      "id": "streets-remember",
      "name": "The Streets Remember",
      "subtitle": "Britt-Inger's warnings start to sound less like folklore.",
      "description": "Fjodor and Folke begin where the city still feels familiar, but routes, sounds, and shadows are already shifting.",
      "accent": "#ffd666",
      "mapTint": "#10233b",
      "storyIntro": "Soder still looks like home. It just no longer behaves like it.",
      "storyOutro": "By the end of the first world, Fjodor knows the island is answering to an older story."
    },
    {
      "id": "hidden-routes",
      "name": "The Hidden Routes",
      "subtitle": "The brothers start reading the city the way Britt-Inger did.",
      "description": "Birds cut strange patterns overhead, old markings return, and Fjodor's languages help him hear what the streets are trying to say.",
      "accent": "#6fe8ff",
      "mapTint": "#0a2631",
      "storyIntro": "What looked like noise becomes direction. What sounded like rumor becomes instruction.",
      "storyOutro": "By the end of the second world, dragon signs are no longer abstract. They are tactical."
    },
    {
      "id": "ember-under-soder",
      "name": "The Ember Under Soder",
      "subtitle": "Dragons stop hiding in stories and start shaping the night.",
      "description": "Ash, heat, and fear twist the same island into something mythic. Fjodor and Folke finally see the shape under the city.",
      "accent": "#ff8a5b",
      "mapTint": "#2b1717",
      "storyIntro": "Britt-Inger was never warning Fjodor about make-believe. She was warning him about timing.",
      "storyOutro": "The campaign ends with the brothers holding a city that now remembers them too."
    }
  ],
